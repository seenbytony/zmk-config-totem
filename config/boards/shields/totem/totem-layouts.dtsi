#include <physical_layouts.dtsi>

/ {
    aonami_layout: aonami_layout {
        compatible = "zmk,physical-layout";
        display-name = "AONAMI Keyboard Layout";

        //kscan = <&kscan0>;
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100  100   77  (-800)   200   232>
            , <&key_physical_attrs 100 100  200   32  (-400)   300   220>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   32       0     0     0>
            , <&key_physical_attrs 100 100  500   44       0     0     0>
            , <&key_physical_attrs 100 100  919   44       0     0     0>
            , <&key_physical_attrs 100 100 1019   32       0     0     0>
            , <&key_physical_attrs 100 100 1119    0       0     0     0>
            , <&key_physical_attrs 100 100 1219   32     400  1219   220>
            , <&key_physical_attrs 100 100 1319   77     800  1319   232>
            , <&key_physical_attrs 100 100    0  140  (-800)   200   232>
            , <&key_physical_attrs 100 100  100  177  (-800)   200   232>
            , <&key_physical_attrs 100 100  200  132  (-400)   300   220>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  132       0     0     0>
            , <&key_physical_attrs 100 100  500  144       0     0     0>
            , <&key_physical_attrs 100 100  630  180       0     0     0>
            , <&key_physical_attrs 100 100  789  180       0     0     0>
            , <&key_physical_attrs 100 100  919  144       0     0     0>
            , <&key_physical_attrs 100 100 1019  132       0     0     0>
            , <&key_physical_attrs 100 100 1119  100       0     0     0>
            , <&key_physical_attrs 100 100 1219  132     400  1219   220>
            , <&key_physical_attrs 100 100 1319  177     800  1319   232>
            , <&key_physical_attrs 100 100 1419  140     800  1319   232>
            , <&key_physical_attrs 100 100    0  240  (-800)   200   232>
            , <&key_physical_attrs 100 100  100  277  (-800)   200   232>
            , <&key_physical_attrs 100 100  200  232  (-400)   300   220>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  232       0     0     0>
            , <&key_physical_attrs 100 100  500  244       0     0     0>
            , <&key_physical_attrs 100 100  919  244       0     0     0>
            , <&key_physical_attrs 100 100 1019  232       0     0     0>
            , <&key_physical_attrs 100 100 1119  200       0     0     0>
            , <&key_physical_attrs 100 100 1219  232     400  1219   220>
            , <&key_physical_attrs 100 100 1319  277     800  1319   232>
            , <&key_physical_attrs 100 100 1419  240     800  1319   232>
            , <&key_physical_attrs 100 100  390  360       0     0     0>
            , <&key_physical_attrs 100 100  490  350    1500   450   432>
            , <&key_physical_attrs 100 100  588  365    3000   548   453>
            , <&key_physical_attrs 100 100  831  365 (-3000)   971   453>
            , <&key_physical_attrs 100 100  929  350 (-1500)  1069   432>
            , <&key_physical_attrs 100 100 1029  360       0     0     0>
            ;
    };
};

